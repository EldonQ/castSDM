# castSDM_config.yaml — template configuration for `cast_run_from_config()`
#
# Quick-start:
#   1. Copy this file to your project and rename it (e.g. `my_run.yaml`)
#   2. Fill in the data paths, models, and any optional pipeline settings
#   3. Run:
#        castSDM::cast_run_from_config("my_run.yaml")
#
# All paths are interpreted RELATIVE to the directory containing this file.
# Anything left commented out keeps cast_batch()'s default.
# ---------------------------------------------------------------------------

run:
  output_dir: "castSDM_output"
  seed: 1234
  parallel: true
  # Optional: per-Windows worker_budget — total cores split across species
  # and intra-species fan-out (see ?cast_worker_budget).
  worker_budget:
    total_workers: 8         # null/omit → uses parallel::detectCores() - 1
  # If true and output_dir already has finished species, skip them.
  resume: true

# Per-species data CSVs. One key = one species; names are used as the
# species id (figures, subdirectories, results).
# Each CSV must contain at least: lon, lat, presence + environmental columns.
species:
  species_a:
    file: "data/species_a.csv"
  species_b:
    file: "data/species_b.csv"

# Optional shared environmental grid for spatial prediction (HSS maps).
# Leave commented to skip prediction.
# env_data:
#   file: "data/env_grid.csv"

# Models to fit per species. Currently supported: cast (CI-MLP), rf,
# maxent, brt, gam, esm. Use "esm" for rare species (low presence count).
models: [cast, rf, maxent, brt]

# CI-MLP (cast) backend: "r" = pure-R CPU implementation (default,
# Windows-friendly, no Rtools), "torch" = legacy GPU/CPU torch backend.
backend: r

# ---------- Pipeline configuration --------------------------------------
# Any key under `cast_batch_args` is forwarded as a named argument to
# cast_batch(). See ?cast_batch for the full catalogue.
cast_batch_args:
  train_fraction: 0.7
  fig_dpi: 300
  do_cv: true
  cv_k: 5
  cv_block_method: grid
  do_cate: true
  cate_top_n: 3
  cate_n_trees: 1000
  dag_R: 100
  dag_strength_threshold: 0.7
  dag_direction_threshold: 0.6
  ate_K: 5
  ate_alpha: 0.05
  do_shap: false
